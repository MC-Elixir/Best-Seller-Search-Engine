# Alibaba 1688 Open Platform
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=

# LLM (choose one)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Proxy (optional)
HTTP_PROXY=
HTTPS_PROXY=
# Proxy list file, one per line: protocol://user:pass@host:port
PROXY_FILE=

# Database
DATABASE_URL=sqlite:///./data/arbitrage.db

# Runtime
LOG_LEVEL=INFO
USE_MOCK_DATA=true
USE_STEALTH=true

# Scheduler
SCHEDULE_ENABLED=false
SCHEDULE_CRON=0 8 * * *
